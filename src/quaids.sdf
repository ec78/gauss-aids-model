#ifndef QUAIDS_SDF_INCLUDED
#define QUAIDS_SDF_INCLUDED

struct quaidsControl {
    matrix maxiter;
    matrix alpha0;
    string othnam;
    matrix linear;
    matrix homogenous;
    matrix err;
    matrix b0;
};

/*
** quaidsOut -- struct returned by quaidsFit() (and, via its qOut.b/v/bS/vS
** fields, the raw legacy return values of quaids()). See the Milestone 1
** section of GOLD_STANDARD_TODO.md and the CLAUDE.md field-by-field notes
** for how each block maps back to the pre-Milestone-1 printed tables.
*/
struct quaidsOut {
    // Metadata
    string model;              // "LA-AIDS" | "AIDS" | "QUAIDS"
    matrix linear;
    matrix homogenous;
    matrix maxiter;
    matrix alpha0;
    matrix nobs;
    matrix n;                  // number of goods
    matrix nint;                // number of extra intercept-shifter variables
    matrix ninst;               // number of instruments
    matrix nu;                  // number of endogenous total-expenditure regressors
    matrix nendog;
    matrix n1;                  // n - homogenous
    matrix ng;
    matrix nz;
    matrix iterations;
    matrix converged;
    matrix finalErr;
    matrix iterHistory;         // Kx2: iteration number, convergence criterion
    // Name vectors below are legacy character matrices built with $+/ftocv,
    // not the newer native "string array" type -- must stay typed "matrix".
    matrix xnam;
    matrix wnam;
    matrix znam;
    matrix unam;
    matrix enam;
    matrix intcptFull;          // intcpt with the constant column prepended
    matrix u;                   // first-stage IV residuals

    // Instrumental-variables first-stage regression (log total expenditure on instruments)
    matrix ivB;
    matrix ivSE;
    matrix ivT;
    matrix ivPvt;
    matrix ivCor;
    matrix ivTv;
    matrix ivRsq;
    matrix ivRbsq;
    matrix ivSse;
    matrix ivStdest;
    matrix ivFstat;
    matrix ivPvf;
    matrix ivDf;

    // Homogeneity-constrained (or unconstrained, if not homogenous) share-system estimates
    matrix homogB;
    matrix homogV;
    matrix homogSE;
    matrix homogT;
    matrix homogPvt;
    matrix homogCor;
    matrix homogTv;
    matrix homogRsq;
    matrix homogRbsq;
    matrix homogSse;
    matrix homogStdest;
    matrix homogFstat;
    matrix homogPvf;
    matrix homogDf;
    matrix homogCrit;

    // Overidentification test (valid only when ninst > nu)
    matrix overidValid;
    matrix overidGamma;
    matrix overidSE;
    matrix overidT;
    matrix overidPvt;
    matrix overidFstat;
    matrix overidPvf;
    matrix overidDf;

    // Symmetry test given homogeneity (valid only when homogenous == 1)
    matrix symValid;
    matrix symStat;
    matrix symPval;
    matrix symDf;

    // Symmetry-constrained share-system estimates (valid only when homogenous == 1)
    matrix symcB;
    matrix symcV;
    matrix symcSE;
    matrix symcT;
    matrix symcPvt;
    matrix symcRsq;
    matrix symcRbsq;
    matrix symcSse;
    matrix symcStdest;
    matrix symcCrit;

    // Final absolute-price-form estimates -- what quaids() returns as (b1, v1, b2, v2)
    matrix b;
    matrix v;
    matrix bS;
    matrix vS;

    // "Best available" estimates for downstream elasticities/Slutzky diagnostics:
    // symmetry-constrained if homogeneity was imposed, else the recovered
    // unconstrained fit.
    matrix bestB;
    matrix bestV;
};

/*
** quaidsElasOut -- struct returned by quaidsElasFit(): income and price
** elasticities (and their delta-method standard errors) at a single
** evaluation point. See the Milestone 5 section of GOLD_STANDARD_TODO.md.
*/
struct quaidsElasOut {
    matrix n;      // number of goods
    matrix wnam;   // legacy character matrix of good names (see quaidsOut.wnam)
    matrix er;     // n x 1, income elasticities
    matrix ep;     // n x n, uncompensated (Marshallian) price elasticities
    matrix epc;    // n x n, compensated (Hicksian) price elasticities
    matrix ser;    // n x 1, delta-method standard errors of er
    matrix sep;    // n x n, delta-method standard errors of ep
    matrix sepc;   // n x n, delta-method standard errors of epc
};

/*
** quaidsCurvOut -- struct returned by quaidsCurvatureFit(): a homogeneity+
** symmetry-constrained AIDS/LA-AIDS fit re-estimated under an additional
** local curvature (Slutzky negative semidefiniteness) restriction at the
** sample mean, via the Diewert-Wales Cholesky reparametrization. See the
** Milestone 10 section of GOLD_STANDARD_TODO.md.
*/
struct quaidsCurvOut {
    matrix n;         // number of goods
    matrix n1;        // n - 1 (size of the reparametrized Cholesky factor)
    matrix nint;      // number of extra intercept-shifter variables
    matrix wnam;      // legacy character matrix of good names
    matrix cholA;     // n1 x n1, the estimated lower-triangular Cholesky factor
    matrix b;         // curvature-constrained coefficient matrix, same row
                      //   layout as qOut.bestB (intercept | gamma | beta | u)
    matrix v;         // covariance of vec(b), via the delta method
    matrix se;        // standard errors, same shape as b
    matrix gama;      // n x n curvature-constrained price-effect matrix
                      //   (also b's gamma block, kept separately for convenience)
    matrix converged; // 1 if the outer iteration converged, 0 otherwise
    matrix iterations;
    matrix finalErr;
    matrix intcptPt;  // reference point used to impose curvature (sample means)
    matrix pricesPt;
    matrix totexpPt;
    matrix eigenvalues;      // n x 1, Slutzky-matrix eigenvalues at the
                              //   reference point (<=0 to numerical
                              //   precision, by construction)
};

#endif
